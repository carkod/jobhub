{
  "name": "back",
  "version": "1.0.0",
  "description": "Back-end application for Jobhub",
  "main": "server.js",
  "scripts": {
    "start": "npm run watch-sass & nodemon --exec babel-node -- src/server.js",
    "watch-sass": "sass --watch src/pdf/styles/:src/pdf/assets/",
    "build-js": "babel src --copy-files --extensions .js --ignore pdf/styles --out-dir dist",
    "build-sass": "sass src/pdf/styles/:dist/pdf/styles/",
    "build": "npm run build-js && npm run build-sass",
    "format": "prettier --write \"src/**/*.{js,jsx,css,scss,json,md}\" \"*.{js,json,md}\"",
    "production": "node dist/server.js",
    "clean": "rm -rf docs node_modules dist src/pdf/assets"
  },
  "keywords": [
    "back-end",
    "mongoose",
    "mongodb",
    "expressjs"
  ],
  "author": "Carlos Wu",
  "license": "ISC",
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@google-cloud/vertexai": "^1.12.0",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "dotenv": "^16.0.1",
    "express": "^4.22.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.4.0",
    "express-validator": "^6.14.2",
    "i18n": "^0.15.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.29.4",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^6.4.0",
    "mongoose": "^6.13.9",
    "mongoose-slug-updater": "^3.2.3",
    "multer": "^2.2.0",
    "pug": "^3.0.4",
    "puppeteer": "^19.6.3",
    "sass": "^1.55.0",
    "semantic-ui-css": "^2.5.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/node": "^7.29.7",
    "@babel/plugin-transform-flow-strip-types": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "nodemon": "^2.0.6",
    "prettier": "^3.8.3"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      "@babel/plugin-transform-runtime",
      "@babel/plugin-transform-flow-strip-types"
    ]
  }
}
